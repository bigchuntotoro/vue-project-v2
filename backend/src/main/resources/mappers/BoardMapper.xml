<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- 매퍼 인터페이스의 전체 경로와 일치해야 매핑됩니다. -->
<mapper namespace="com.example.demo.mapper.BoardMapper">

    <!-- 1. 게시글 목록 조회 (검색 + 페이징) -->
    <select id="selectBoardList" resultType="com.example.demo.model.BoardDTO">
        SELECT * FROM vueboard
        <where>
            <if test="searchKeyword != null and searchKeyword != ''">
                <choose>
                    <when test="searchType == 'title'">
                        AND title LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'writer'">
                        AND writer LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'content'">
                        AND content LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <otherwise>
                        <!-- 'all' 일 때: 제목 OR 내용 -->
                        AND (title LIKE CONCAT('%', #{searchKeyword}, '%')
                        OR content LIKE CONCAT('%', #{searchKeyword}, '%'))
                    </otherwise>
                </choose>
            </if>
        </where>
        ORDER BY board_id DESC
        LIMIT #{offset}, #{size}
    </select>

    <!-- 2. 전체 개수 조회 (검색 조건 적용) -->
    <select id="selectBoardCount" resultType="int">
        SELECT COUNT(*) FROM vueboard
        <where>
            <if test="searchKeyword != null and searchKeyword != ''">
                <choose>
                    <when test="searchType == 'title'">
                        AND title LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'writer'">
                        AND writer LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'content'">
                        AND content LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <otherwise>
                        AND (title LIKE CONCAT('%', #{searchKeyword}, '%')
                        OR content LIKE CONCAT('%', #{searchKeyword}, '%'))
                    </otherwise>
                </choose>
            </if>
        </where>
    </select>

    <!-- 게시글 상세 조회 -->
    <select id="selectBoardById" parameterType="int" resultType="com.example.demo.model.BoardDTO">
        SELECT board_id, title, content, writer, reg_date, view_cnt
        FROM vueboard
        WHERE board_id = #{boardId}
    </select>

    <!-- 게시글 등록 -->
    <insert id="insertBoard" parameterType="com.example.demo.model.BoardDTO">
        INSERT INTO vueboard (title, content, writer)
        VALUES (#{title}, #{content}, #{writer})
    </insert>

    <!-- 게시글 수정 -->
    <update id="updateBoard" parameterType="com.example.demo.model.BoardDTO">
        UPDATE vueboard
        SET title = #{title}, content = #{content}
        WHERE board_id = #{boardId}
    </update>

    <!-- 게시글 삭제 -->
    <delete id="deleteBoard" parameterType="int">
        DELETE FROM vueboard WHERE board_id = #{boardId}
    </delete>

    <!-- 조회수 증가 -->
    <update id="updateViewCount" parameterType="int">
        UPDATE vueboard
        SET view_cnt = view_cnt + 1
        WHERE board_id = #{boardId}
    </update>

</mapper>